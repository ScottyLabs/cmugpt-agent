# Required: OpenRouter API key for LLM access
OPENROUTER_API_KEY=

# Optional: MCP server URL for tool access
MCP_SERVER_URL=

# Optional: Shared secret for authenticating /agent/respond* requests
AGENT_SHARED_SECRET=

# --- Email Interface ---
# Set EMAIL_ENABLED=true to start the Gmail polling worker
EMAIL_ENABLED=false

# Gmail address to poll for inbound emails (use + addressing for filtering)
EMAIL_TARGET_ADDRESS=

# Seconds between Gmail poll cycles
EMAIL_POLL_INTERVAL=60

# Model to use for email responses (via OpenRouter)
EMAIL_MODEL=openai/gpt-4o

# Google OAuth credentials (one of these is required for the email interface):
# Option A: path to a service-account or OAuth client-secrets JSON file
GOOGLE_CREDENTIALS_FILE=credentials.json
# Option B: the full JSON contents of the credentials file (for deployment)
GOOGLE_CREDENTIALS_JSON=
# Option C: cached user OAuth token as JSON (for deployment)
GOOGLE_TOKEN_JSON=
