# Required: OpenRouter API key for LLM access
OPENROUTER_API_KEY=

# Optional: MCP server URL for tool access
MCP_SERVER_URL=

# Optional: Shared secret for authenticating /agent/respond* requests
AGENT_SHARED_SECRET=

# --- Email Interface ---
# Set EMAIL_ENABLED=true to start the Gmail polling worker
EMAIL_ENABLED=false

# Gmail address to poll for inbound emails (use + addressing for filtering)
EMAIL_TARGET_ADDRESS=

# Seconds between Gmail poll cycles
EMAIL_POLL_INTERVAL=60

# Model to use for email responses (via OpenRouter)
EMAIL_MODEL=openai/gpt-4o

# Google OAuth credentials (legacy direct mode, used as fallback):
# Option A: path to a service-account or OAuth client-secrets JSON file
GOOGLE_CREDENTIALS_FILE=credentials.json
# Option B: the full JSON contents of the credentials file (for deployment)
GOOGLE_CREDENTIALS_JSON=
# Option C: cached user OAuth token as JSON (for deployment)
GOOGLE_TOKEN_JSON=

# --- Keycloak (primary OAuth provider for per-user Gmail) ---
# Keycloak server URL (e.g. https://keycloak.your-domain.com)
KEYCLOAK_SERVER_URL=
# Keycloak realm name
KEYCLOAK_REALM=cmugpt
# OIDC client ID registered in Keycloak
KEYCLOAK_CLIENT_ID=cmugpt-agent
# OIDC client secret
KEYCLOAK_CLIENT_SECRET=
# Admin credentials (required — used to auto-grant the broker read-token
# role so the agent can retrieve Google tokens via Keycloak)
KEYCLOAK_ADMIN_USERNAME=
KEYCLOAK_ADMIN_PASSWORD=
# Alias of the Google identity provider in Keycloak (default: "google")
KEYCLOAK_GOOGLE_IDP_ALIAS=google

# Base URL for OAuth redirect (per-user Gmail auth callback)
# Example: https://your-domain.com or http://localhost:8000
OAUTH_REDIRECT_BASE_URL=
